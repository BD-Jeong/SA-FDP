+/* Allow BPF to set only struct bio's bi_write_stream (FDP write stream). */
+BPF_CALL_2(bpf_probe_write_kernel_bio_write_stream, struct bio *, bio, u8, stream_id)
+{
+	if (!bio)
+		return -EINVAL;
+	return copy_to_kernel_nofault(&bio->bi_write_stream, &stream_id, sizeof(stream_id));
+}
+
+static const struct bpf_func_proto bpf_probe_write_kernel_bio_write_stream_proto = {
+	.func		= bpf_probe_write_kernel_bio_write_stream,
+	.gpl_only	= true,
+	.ret_type	= RET_INTEGER,
+	.arg1_type	= ARG_ANYTHING,
+	.arg2_type	= ARG_ANYTHING,
+};
+
 #define MAX_TRACE_PRINTK_VARARGS	3
 #define BPF_TRACE_PRINTK_SIZE		1024
 
@@ -1495,6 +1512,9 @@ bpf_trace_func_proto(enum bpf_func_id func_id, const struct bpf_prog *prog)
 	switch (func_id) {
 	case BPF_FUNC_probe_write_user:
 		return security_locked_down(LOCKDOWN_BPF_WRITE_USER) < 0 ?
